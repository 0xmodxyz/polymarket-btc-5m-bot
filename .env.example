# =============================================================================
# Polymarket CLOB — required fields
# =============================================================================
# CLOB API key/secret/passphrase are NOT stored in .env.
# py-clob-client auto-derives them from PRIVATE_KEY (create_or_derive_api_creds).
#
# For Email/Magic accounts:
#   PRIVATE_KEY  = Exported signer private key (Polymarket settings)
#   FUNDER       = Profile address (0x... from polymarket.com/@you)
#                  NOT your deposit wallet address!
#   SIGNATURE_TYPE = 1 (email/Magic)

POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER=0x...
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_CHAIN_ID=137

# =============================================================================
# Relayer API (optional — not used by current bot)
# =============================================================================
# Key from Polymarket "Builder / Relayer" screen; used for gasless redeem etc.
# Not required for regular CLOB trading.


# POLYMARKET_RELAYER_API_KEY=
# POLYMARKET_RELAYER_API_KEY_ADDRESS=0x...

# =============================================================================
# Risk limits (USD)
# =============================================================================
MAX_BUDGET_USD=50
MAX_PER_WINDOW_USD=5
TEST_ORDER_USD=1
